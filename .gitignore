# Secrets -- never commit real keys. Real values found and verified
# excluded during pre-push audit: root .env (ROBOFLOW_API_KEY),
# rag_engine/.env (GEMINI_API_KEY). See VERIFICATION.md/README for the
# .env.example convention.
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Node / frontend build output
node_modules/
.next/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Model checkpoints and training-run artifacts -- large, reproducible from
# source (YOLO weights are downloaded/fine-tuned, not hand-authored).
*.pt
*.joblib
runs/

# Video data -- large (data/ alone is ~1.6GB of source clips). Ground-truth
# annotation CSVs and sanity-check frames under data/cv_annotated/ are
# intentionally NOT covered by these patterns and stay tracked -- see
# README.md/VERIFICATION.md for what's included vs. what a reader needs to
# supply themselves.
data/*.mp4
data/tennis/*.mp4
data/cv_annotated/videos/
data/rendered/

# Ad-hoc debug/investigation output (crop images, per-frame dumps) built up
# during iterative CV pipeline debugging -- 1849 files / 329MB as of the
# pre-push audit, not source, not needed to follow PROGRESS.md's narrative
# (which describes every finding in prose). See VERIFICATION.md for the one
# specific docstring reference (reference_video2_calibration.py) this
# affects and why it's still resolvable without these files.
cv_pipeline/scratch_output/

# ML experiment-tracking / training-run artifacts -- auto-generated by
# re-running the relevant pipeline/training scripts, not source.
.coverage
mlflow.db
catboost_info/

# Raw captured stdout logs from milestone pipeline runs -- redundant with
# the prose "freeze" docs under tennis-intelligence-platform/docs/, which
# already narrate each milestone for a reader.
tennis-intelligence-platform/day*_output.txt

# OS
.DS_Store

# Editors
.vscode/
.idea/
